{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{ printf "<?xml-stylesheet href=\"/pretty-feed-v3.xsl\" type=\"text/xsl\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:content="http://purl.org/rss/1.0/modules/content/" xmlns:webfeeds="http://webfeeds.org/rss/1.0">
  <channel>
    <title>{{ if .IsHome }}{{ .Site.Title }}{{ else }}{{ with .Title }}{{ . }} on {{ end }}{{ .Site.Title }}{{ end }}</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <generator>Hugo</generator>
    <language>{{ .Site.Language.Lang }}</language>
    {{- with .Site.Copyright }}
    <copyright>{{ . }}</copyright>
    {{- end }}
    {{- if not .Date.IsZero }}
    <lastBuildDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</lastBuildDate>
    {{- end }}
    {{- with .OutputFormats.Get "RSS" }}
    {{ printf "<atom:link href=%q rel=\"self\" type=%q />" .Permalink .MediaType | safeHTML }}
    {{- end }}
    <image>
      <url>https://terminalvelocity.blog/images/mato_color.jpeg</url>
      <title>{{ .Site.Title }}</title>
      <link>https://terminalvelocity.blog/</link>
    </image>
    <webfeeds:icon>https://terminalvelocity.blog/images/mato_color.jpeg</webfeeds:icon>
    {{- $pages := .RegularPages }}
    {{- if .IsHome }}{{ $pages = .Site.RegularPages }}{{ end }}
    {{- $limit := .Site.Config.Services.RSS.Limit }}
    {{- if ge $limit 1 }}{{ $pages = $pages | first $limit }}{{ end }}
    {{- range $pages }}
    <item>
      <title>{{ .Title }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" | safeHTML }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      <description>{{ .Summary | transform.XMLEscape | safeHTML }}</description>
      <content:encoded>{{ `<![CDATA[` | safeHTML }}{{ .Content | safeHTML }}{{ `]]>` | safeHTML }}</content:encoded>
    </item>
    {{- end }}
  </channel>
</rss>
